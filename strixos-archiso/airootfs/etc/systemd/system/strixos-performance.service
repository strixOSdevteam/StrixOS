[Unit]
Description=StrixOS Gaming Performance Tweaks
After=network.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor'
ExecStart=/bin/bash -c 'echo 0 | tee /proc/sys/kernel/nmi_watchdog'
ExecStart=/bin/bash -c 'echo 1000 | tee /proc/sys/vm/dirty_writeback_centisecs'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
